# Firebase Admin SDK (server-side for /api/*)
# Option 1: single JSON string (recommended)
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n","client_email":"...","client_id":"..."}

# Option 2: split variables (if you do not use FIREBASE_SERVICE_ACCOUNT_KEY)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n"

# Legacy server/telegram integration (server/server.js)
SUPABASE_URL=
SUPABASE_KEY=
TELEGRAM_CONTACT_TOKEN=
TELEGRAM_PAYMENT_TOKEN=
TELEGRAM_CHAT_ID=
